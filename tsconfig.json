{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"outDir": "dist",
		"declaration": true,
		"sourceMap": true
	},
	"include": ["src/**/*.ts", "tests/**/*.ts", "tools/**/*.mjs"],
	"exclude": ["node_modules", "dist"]
}